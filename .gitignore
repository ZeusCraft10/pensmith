# Build output
dist/
*.tsbuildinfo

# Generated by scripts/prebuild.mjs (WR-01 / WR-03 — derived from package.json + verbs.ts)
bin/lib/version.generated.ts
bin/lib/verbs.json

# Node
node_modules/
npm-debug.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
Thumbs.db

# Test artifacts
coverage/
.nyc_output/
# WR-04: per-test temp fixture copies. tests/lint-{thin-shim,mcp-no-network,
# capabilities-noleak}.test.ts each write a fixture into this directory so
# the file-scoped mcp/**/*.ts lint chokepoints fire. The tests clean up
# in finally blocks, but a crash mid-test could leave stale files behind.
mcp/__fixtures__/

# Runtime artifacts
# .paper/ is the active paper workspace created by `pensmith new`.
# ~/.pensmith/ is the global library — outside the repo, listed for awareness only.
.paper/

# Phase 9 tutorial/PII outputs
# The .paper/ line above already ignores these (they live under .paper/), but we
# list them DEFENSIVELY with **/ globs so the guarantee survives if .paper/ is
# ever un-ignored — and so RESEARCH Pitfall 7 (TUTORIAL.md not gitignored) is
# structurally satisfied. TUTORIAL.md is the educator-mode learning artifact;
# INTAKE.raw.local holds UNREDACTED intake answers (PII opt-in) and must NEVER
# be committed.
**/TUTORIAL.md
**/INTAKE.raw.local

# Local-only
.env
.env.local
*.log
.claude/
.planning/graphs/
graphify-out/
